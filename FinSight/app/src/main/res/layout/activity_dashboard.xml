<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado da Pesquisa"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/graphite"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTotalCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quant. de pessoas Entrevistadas: 0"
        android:textSize="16sp"
        android:textColor="@color/dark_gray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnList"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Lista de Entrevistados"
        android:layout_marginTop="48dp"
        style="@style/Widget.FinSight.Button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStats"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Análise de Preferências"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnList"
        style="@style/Widget.FinSight.Button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Limpar Banco de Dados"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnStats"
        style="@style/Widget.FinSight.Button"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
